{
  "name": "active-break-clock",
  "version": "0.4.0",
  "description": "一款强制锁屏的健康提醒应用，帮你打破久坐循环，养成定时活动的好习惯。",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/neopen/active-break-clock.git"
  },
  "keywords": [
    "health",
    "reminder",
    "stand-up",
    "break-reminder",
    "sedentary",
    "electron",
    "desktop-app"
  ],
  "author": "neopen",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/neopen/active-break-clock/issues"
  },
  "homepage": "https://github.com/neopen/active-break-clock#readme",
  "type": "commonjs",
  "build": {
    "appId": "com.neopen.activebreakclock",
    "productName": "别坐了",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!node_modules/.cache",
      "!dist",
      "!docs",
      "!icons",
      "!lock_temp.html"
    ],
    "win": {
      "target": "nsis",
      "icon": "icons/icon-256.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "icons/icon-256.png",
      "category": "public.app-category.healthcare-fitness"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icons/icon-256.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "别坐了"
    }
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^24.13.3"
  }
}