{
  "name": "HealthClock",
  "version": "0.4.5",
  "description": "一款强制锁屏的健康提醒应用，帮你打破久坐循环，养成定时活动的好习惯。",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder --win --mac --linux",
    "postinstall": "electron-builder install-app-deps",
    "pack": "electron-builder --dir"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/neopen/active-break-clock.git"
  },
  "keywords": [
    "health",
    "reminder",
    "stand-up",
    "break-reminder",
    "sedentary",
    "electron",
    "desktop-app",
    "productivity",
    "wellness",
    "ergonomic"
  ],
  "author": {
    "name": "neopen",
    "email": "helpenx+clock@gmail.com",
    "url": "https://github.com/neopen"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/neopen/active-break-clock/issues"
  },
  "homepage": "https://github.com/neopen/active-break-clock#readme",
  "type": "commonjs",
  "build": {
    "appId": "com.neopen.activebreakclock",
    "productName": "HealthClock",
    "copyright": "Copyright © 2026 neopen",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "**/*",
      "!node_modules/.cache",
      "!dist",
      "!docs",
      "!icons",
      "!lock_temp.html",
      "!*.md",
      "!*.log",
      "!.git",
      "!.github"
    ],
    "win": {
      "target": "nsis",
      "icon": "icons/icon-256.png",
      "publisherName": "neopen",
      "artifactName": "HealthClock_x64_${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "别坐了",
      "perMachine": true,
      "runAfterFinish": true,
      "artifactName": "HealthClock_x64_${version}.${ext}"
    },
    "mac": {
      "target": "dmg",
      "icon": "icons/icon-256.png",
      "category": "public.app-category.healthcare-fitness",
      "artifactName": "HealthClock_${version}.${ext}"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icons/icon-256.png",
      "category": "Utility",
      "artifactName": "HealthClock_${version}.${ext}"
    },
    "asar": true,
    "compression": "maximum"
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^24.13.3"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "private": false
}