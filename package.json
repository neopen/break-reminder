{
  "name": "HealthClock",
  "version": "0.5.3",
  "description": "一款强制锁屏的健康提醒应用，帮你打破久坐循环，养成定时活动的好习惯。",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "electron .",
    "build": "node scripts/build.js",
    "start": "electron .",
    "dist": "npm run build && electron-builder --win --x64",
    "dist:win": "npm run build && electron-builder --win --x64",
    "dist:portable": "npm run build && electron-builder --win --x64 --config.win.target=portable",
    "build:web": "node scripts/build-web.js",
    "clean": "rd /s /q dist release 2>nul"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/neopen/active-break-clock.git"
  },
  "keywords": [
    "health",
    "reminder",
    "stand-up",
    "break-reminder",
    "sedentary",
    "electron",
    "desktop-app",
    "productivity",
    "wellness",
    "ergonomic"
  ],
  "author": {
    "name": "neopen",
    "email": "helpenx+clock@gmail.com",
    "url": "https://github.com/neopen"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/neopen/active-break-clock/issues"
  },
  "homepage": "https://github.com/neopen/active-break-clock#readme",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.0.0"
  }
}