{
  "applicationId": "com.neopen.activebreakclock",
  "appname": "HealthClock",
  "version": "0.6.0",
  "description": "一款强制锁屏的健康提醒应用，帮你打破久坐循环，养成定时活动的好习惯。",
  "defaultMode": "window",
  "documentRoot": "/src/renderer/",
  "url": "/index.html",
  "enableServer": true,
  "enableHTTPS": false,
  "enableNativeAPI": true,
  "tokenSecurity": "one-time",
  "logging": {
    "enabled": true,
    "writeToLogFile": true
  },
  "nativeAllowList": [
    "app.*",
    "os.*",
    "filesystem.*",
    "window.*",
    "process.*",
    "debug.*",
    "storage.*",
    "events.*"
  ],
  "modes": {
    "window": {
      "title": "起来走走 - 拒绝久坐",
      "width": 800,
      "height": 1000,
      "minWidth": 600,
      "minHeight": 800,
      "fullScreen": false,
      "alwaysOnTop": false,
      "center": true,
      "icon": "src/renderer/icons/icon-256.png",
      "label": "main",
      "enableInspector": false,
      "borderless": false,
      "maximize": false,
      "hidden": false,
      "resizable": true,
      "exitProcessOnClose": false,
      "transparent": false,
      "shadow": true,
      "defaultBackgroundOpacity": 1,
      "windowControls": {
        "hide": false,
        "maximize": true,
        "minimize": true
      }
    },
    "lock": {
      "title": "起来走走 - 锁屏",
      "width": 1920,
      "height": 1080,
      "resizable": false,
      "fullscreen": true,
      "alwaysOnTop": true,
      "center": false,
      "icon": "src/renderer/icons/icon-256.png",
      "label": "lock",
      "transparent": false,
      "shadow": false,
      "defaultBackgroundOpacity": 1,
      "enableInspector": false,
      "windowControls": {
        "hide": true,
        "maximize": false,
        "minimize": false
      }
    }
  },
  "tray": {
    "enabled": true,
    "icon": "src/renderer/icons/icon-48.png",
    "menu": [
      {
        "label": "显示主窗口",
        "event": "showMainWindow"
      },
      {
        "label": "退出",
        "event": "exitApp"
      }
    ]
  },
  "cli": {
    "binaryName": "HealthClock",
    "resourcesPath": "/src/renderer/",
    "extensionsPath": "/extensions/",
    "clientLibrary": "src/renderer/js/lib/neutralino.js",
    "preserveWatchOutput": false,
    "disableAutoLoad": false,
    "secure": false,
    "nativeLogger": true,
    "singleInstance": true,
    "binaryVersion": "6.7.0",
    "clientVersion": "6.7.0"
  },
  "extensions": []
}